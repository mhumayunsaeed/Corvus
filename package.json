{
  "name": "corvus",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev --filter=!@corvus/desktop",
    "build": "turbo build --filter=!@corvus/desktop",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:web": "turbo dev --filter=@corvus/web",
    "dev:desktop": "turbo dev --filter=@corvus/desktop",
    "build:web": "turbo build --filter=@corvus/web",
    "build:desktop": "turbo build --filter=@corvus/desktop"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript-eslint": "^8.60.1",
    "typescript": "^5.9.3"
  }
}
