{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Corvus",
  "version": "0.0.1",
  "identifier": "com.corvus.app",
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/128x128.png",
      "icons/32x32@2x.png"
    ]
  },
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../web/out",
    "beforeDevCommand": "cd ../web && pnpm dev",
    "beforeBuildCommand": "cd ../web && pnpm build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Corvus",
        "url": "/login",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' http://localhost:* https://* ws://* wss://*; img-src 'self' data: https://* http://localhost:*; media-src 'self' data: blob: https://* http://localhost:*; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://player.vimeo.com https://twitframe.com https://platform.twitter.com;"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://veyra-web-rzp5.vercel.app/api/updater"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYyQzQ5Qzk1NkVFMzgyQUUKUldTdWd1TnVsWnpFOHZVWVUxamd4YmNWM1I5dUtLcEtxR2ZHTHFSRzNaMmppczUrbWNWWTFocGEK"
    }
  }
}
