{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Veyra",
  "version": "0.0.1",
  "identifier": "com.veyra.app",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../web/out",
    "beforeDevCommand": "cd ../web && pnpm dev",
    "beforeBuildCommand": "cd ../web && pnpm build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Veyra",
        "url": "/login",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' http://localhost:* https://*; img-src 'self' data: https://*"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://veyra-web-rzp5.vercel.app/api/updater"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYyQzQ5Qzk1NkVFMzgyQUUKUldTdWd1TnVsWnpFOHZVWVUxamd4YmNWM1I5dUtLcEtxR2ZHTHFSRzNaMmppczUrbWNWWTFocGEK"
    }
  }
}
