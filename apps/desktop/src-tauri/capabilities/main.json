        "core:window:allow-is-maximized",
        "core:window:allow-start-dragging",
        "notification:default",
        "global-shortcut:default",
        "store:default",
        "sql:default",
        "updater:default",
        "os:default",
        "fs:default",
        "dialog:default",
        "deep-link:default",
        "process:default"
    ]
}