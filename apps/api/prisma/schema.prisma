generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  username             String   @unique
  displayName          String   @map("display_name")
  passwordHash         String?  @map("password_hash")
  googleId             String?  @unique @map("google_id")
  avatarUrl            String?  @map("avatar_url")
  bio                  String?
  status               String   @default("offline")
  onboardingCompleted  Boolean  @default(false) @map("onboarding_completed")
  emailVerified        Boolean  @default(false) @map("email_verified")
  emailVerifyToken     String?  @unique @map("email_verify_token")
  emailVerifyExpires   DateTime? @map("email_verify_expires")
  passwordResetToken   String?  @unique @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  ownedServers    Server[]       @relation("ServerOwner")
  memberships     ServerMember[]
  messages        Message[]
  reactions       Reaction[]
  createdInvites  Invite[]
  sentFriendRequests     FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedFriendRequests")
  friends                Friend[]        @relation("UserFriends")
  friendedBy             Friend[]        @relation("FriendOf")
  blocksInitiated        Block[]         @relation("BlocksInitiated")
  blocksReceived         Block[]         @relation("BlocksReceived")
  dmConversationsCreated DMConversation[] @relation("DMConversationCreator")
  dmParticipations       DMParticipant[]
  dmMessages             DMMessage[]
  stickers               Sticker[]
  pinnedDMMessages       PinnedDMMessage[]
  pinnedChannelMessages  PinnedMessage[]
  channelReads           ChannelRead[]
  settings               UserSettings?

  @@map("users")
}

model Server {
  id          String   @id @default(cuid())
  name        String
  iconUrl     String?  @map("icon_url")
  description String?
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner    User           @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  ServerMember[]
  channels Channel[]
  invites  Invite[]
  roles    Role[]
  settings ServerSettings?

  @@map("servers")
}

model ServerMember {
  id       String   @id @default(cuid())
  serverId String   @map("server_id")
  userId   String   @map("user_id")
  role     String   @default("member") // owner, admin, member
  nickname String?
  joinedAt DateTime @default(now()) @map("joined_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedRoles ServerMemberRole[]

  @@unique([serverId, userId])
  @@map("server_members")
}

model Channel {
  id        String   @id @default(cuid())
  serverId  String   @map("server_id")
  name      String
  type      String   @default("text") // text, voice, announcement, forum, stage
  category  String   @default("General")
  topic     String?
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  server               Server                    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages             Message[]
  reads                ChannelRead[]
  permissionOverrides  ChannelPermissionOverride[]
  pinnedMessages       PinnedMessage[]
  boardState           ChannelBoard?
  docsState            ChannelDocs?
  incidentState        ChannelIncident?
  canvasState          ChannelCanvas?
  githubState          ChannelGitHub?

  @@index([serverId])
  @@map("channels")
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model ServerSettings {
  id        String   @id @default(cuid())
  serverId  String   @unique @map("server_id")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@map("server_settings")
}

model ChannelBoard {
  id        String   @id @default(cuid())
  channelId String   @unique @map("channel_id")
  board     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("channel_boards")
}

model ChannelDocs {
  id        String   @id @default(cuid())
  channelId String   @unique @map("channel_id")
  docs      Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("channel_docs")
}

model ChannelIncident {
  id        String   @id @default(cuid())
  channelId String   @unique @map("channel_id")
  incident  Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("channel_incidents")
}

model ChannelCanvas {
  id        String   @id @default(cuid())
  channelId String   @unique @map("channel_id")
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("channel_canvases")
}

model ChannelGitHub {
  id           String   @id @default(cuid())
  channelId    String   @unique @map("channel_id")
  config       Json     @default("{}")
  pullRequests Json     @default("[]") @map("pull_requests")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("channel_github")
}

model ChannelRead {
  id         String   @id @default(cuid())
  channelId  String   @map("channel_id")
  userId     String   @map("user_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@map("channel_reads")
}

model Message {
  id        String    @id @default(cuid())
  channelId String    @map("channel_id")
  authorId  String    @map("author_id")
  content   String
  type      String    @default("default") // default, reply, system
  replyToId String?   @map("reply_to_id")
  editedAt  DateTime? @map("edited_at")
  createdAt DateTime  @default(now()) @map("created_at")

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replyTo   Message?   @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]  @relation("MessageReplies")
  reactions Reaction[]
  embeds    MessageEmbed[]
  pinnedEntries PinnedMessage[]

  @@index([channelId, createdAt])
  @@map("messages")
}

model MessageEmbed {
  id          String   @id @default(cuid())
  messageId   String   @map("message_id")
  url         String
  siteName    String?  @map("site_name")
  title       String?
  description String?
  imageUrl    String?  @map("image_url")
  faviconUrl  String?  @map("favicon_url")
  createdAt   DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_embeds")
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("reactions")
}

model Invite {
  id        String    @id @default(cuid())
  serverId  String    @map("server_id")
  creatorId String    @map("creator_id")
  code      String    @unique
  maxUses   Int?      @map("max_uses")
  uses      Int       @default(0)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("invites")
}

model FriendRequest {
  id         String    @id @default(cuid())
  senderId   String    @map("sender_id")
  receiverId String    @map("receiver_id")
  status     String    @default("pending") // pending, accepted, declined, canceled
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  respondedAt DateTime? @map("responded_at")

  sender   User @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
  @@map("friend_requests")
}

model Friend {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([friendId])
  @@map("friends")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("user_blocks")
}

model Sticker {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String   @map("image_url") // Supabase Storage public URL
  creatorId String   @map("creator_id")
  createdAt DateTime @default(now()) @map("created_at")

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@map("stickers")
}

model DMConversation {
  id          String   @id @default(cuid())
  type        String   @default("direct") // direct, group
  name        String?
  directKey   String?  @unique @map("direct_key")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy      User            @relation("DMConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants   DMParticipant[]
  messages       DMMessage[]
  pinnedMessages PinnedDMMessage[]

  @@index([updatedAt])
  @@map("dm_conversations")
}

model DMParticipant {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  conversation DMConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, joinedAt])
  @@map("dm_participants")
}

model DMMessage {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  authorId       String    @map("author_id")
  content        String
  type           String    @default("default") // default, reply, call
  replyToId      String?   @map("reply_to_id")
  metadata       String?   // JSON string with extra details (e.g. call duration)
  editedAt       DateTime? @map("edited_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation   DMConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replyTo        DMMessage?      @relation("DMMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        DMMessage[]     @relation("DMMessageReplies")
  pinnedEntries  PinnedDMMessage[]

  @@index([conversationId, createdAt])
  @@map("dm_messages")
}

model PinnedDMMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  messageId      String   @map("message_id")
  pinnedById     String   @map("pinned_by_id")
  pinnedAt       DateTime @default(now()) @map("pinned_at")

  conversation DMConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      DMMessage      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy     User           @relation(fields: [pinnedById], references: [id], onDelete: Cascade)

  @@unique([conversationId, messageId])
  @@index([conversationId])
  @@map("pinned_dm_messages")
}

model PinnedMessage {
  id         String   @id @default(cuid())
  channelId  String   @map("channel_id")
  messageId  String   @map("message_id")
  pinnedById String   @map("pinned_by_id")
  pinnedAt   DateTime @default(now()) @map("pinned_at")

  channel  Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy User    @relation(fields: [pinnedById], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
  @@index([channelId])
  @@map("pinned_messages")
}

// ─── Roles & Permissions ─────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  serverId    String   @map("server_id")
  name        String
  color       String?  // hex color for display (e.g. "#7C3AED")
  position    Int      @default(0)  // higher = more authority
  permissions Int      @default(0)  // bitfield of granted permissions
  isDefault   Boolean  @default(false) @map("is_default") // true = @everyone role
  createdAt   DateTime @default(now()) @map("created_at")

  server           Server                    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members          ServerMemberRole[]
  channelOverrides ChannelPermissionOverride[]

  @@unique([serverId, name])
  @@index([serverId])
  @@map("roles")
}

model ServerMemberRole {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  roleId   String @map("role_id")

  member ServerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role   Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([memberId, roleId])
  @@map("server_member_roles")
}

// ─── Realtime / call state ───────────────────────────────────────
// Previously held in-memory in the WebSocket server. Moved to the DB so it
// survives across stateless (serverless) API invocations.

model VoiceParticipant {
  id          String   @id @default(cuid())
  channelId   String   @map("channel_id")
  userId      String   @map("user_id")
  username    String
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  joinedAt    DateTime @default(now()) @map("joined_at")

  @@unique([channelId, userId])
  @@index([channelId])
  @@map("voice_participants")
}

model StageParticipant {
  id        String @id @default(cuid())
  channelId String @map("channel_id")
  userId    String @map("user_id")
  role      String // "speaker" | "raised_hand"

  @@unique([channelId, userId])
  @@index([channelId])
  @@map("stage_participants")
}

model CallRoom {
  id             String   @id @default(cuid())
  conversationId String   @unique @map("conversation_id")
  roomName       String   @map("room_name")
  startedAt      DateTime @default(now()) @map("started_at")

  participants CallParticipant[]

  @@map("call_rooms")
}

model CallParticipant {
  id       String   @id @default(cuid())
  roomId   String   @map("room_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  room CallRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@map("call_participants")
}

model ChannelPermissionOverride {
  id        String @id @default(cuid())
  channelId String @map("channel_id")
  roleId    String @map("role_id")
  allow     Int    @default(0)  // bitfield of explicitly allowed perms
  deny      Int    @default(0)  // bitfield of explicitly denied perms

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([channelId, roleId])
  @@map("channel_permission_overrides")
}
