# ─── Database (Supabase Postgres) ────────────────────────────────
# Use the *pooled* connection string (port 6543, pgbouncer) for the app,
# and the *direct* connection (port 5432) for Prisma migrations.
# Find both under: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Supabase (server-side) ──────────────────────────────────────
# Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — never expose to the browser
SUPABASE_ANON_KEY=your-anon-key

# ─── App session token ───────────────────────────────────────────
# The API verifies the Supabase access token, then issues its own short JWT
# used for all subsequent API/WebSocket auth.
JWT_SECRET=replace-with-a-long-random-secret

# Frontend URL used in CORS (and email links if you re-enable server email)
FRONTEND_URL=http://localhost:3000

# Optional extra CORS origins (comma-separated)
CORS_ORIGINS=

# ─── Voice/Video (LiveKit) ───────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

NODE_ENV=development
PORT=3001
