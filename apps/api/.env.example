# Required
DATABASE_URL=postgresql://user:password@localhost:5432/veyra
JWT_SECRET=replace-with-a-long-random-secret

# Frontend URL used in email links and CORS
FRONTEND_URL=http://localhost:3000

# Optional extra CORS origins (comma-separated)
CORS_ORIGINS=

# Optional email provider settings
RESEND_API_KEY=
EMAIL_FROM=Veyra <noreply@veyra.app>

# Optional voice/video settings (required for call features)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

NODE_ENV=development
PORT=3001
